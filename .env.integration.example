# Integration test secrets — copy to .env.integration and fill in only the
# vars for the tool-group tags you want to run. `make setup-test-env` writes
# this file from Vault automatically; this example documents the same set
# for local-only setups (no Vault access).
#
# Non-secret config (bootstrap servers, REST endpoints, cluster/env/pool/org
# IDs, catalog/database names) lives in
# `test-fixtures/yaml_configs/integration.yaml` — update it there, not here.
#
# Tests gate on their own credential subset and skip when their vars are
# empty, so partial setups are fine.

# --- @kafka (admin client + REST proxy) ---
KAFKA_API_KEY=
KAFKA_API_SECRET=

# --- @schema (Schema Registry) ---
SCHEMA_REGISTRY_API_KEY=
SCHEMA_REGISTRY_API_SECRET=

# --- @clusters / @environments / @connect / @catalog / @search / @billing (CCloud control plane) ---
CONFLUENT_CLOUD_API_KEY=
CONFLUENT_CLOUD_API_SECRET=
CONFLUENT_CLOUD_USERNAME=
CONFLUENT_CLOUD_PASSWORD=

# --- @flink ---
FLINK_API_KEY=
FLINK_API_SECRET=

# --- @tableflow ---
TABLEFLOW_API_KEY=
TABLEFLOW_API_SECRET=

# --- @metrics (Telemetry API) ---
TELEMETRY_API_KEY=
TELEMETRY_API_SECRET=

# --- @cp (self-managed Confluent Platform via docker-compose.cp-test.yml) ---
# Start the local CP stack first: docker compose -f docker-compose.cp-test.yml up -d
# Non-secret config (bootstrap_servers, SR endpoint) lives in
# test-fixtures/yaml_configs/integration.cp.yaml.
CP_KAFKA_USERNAME=mcp
CP_KAFKA_PASSWORD=mcp-secret
