# Integration test environment — copy to .env.integration and fill in only the
# vars for the tool-group tags you want to run. Tests gate on their own
# credential subset and skip when their vars are empty, so you do not need
# to populate every field.

# --- @kafka (admin client: list/create/delete topics, produce/consume messages) ---
BOOTSTRAP_SERVERS=
KAFKA_API_KEY=
KAFKA_API_SECRET=

# --- @kafka (REST proxy: alter/get topic config) ---
# KAFKA_REST_ENDPOINT typically looks like:
#   https://pkc-xxxxx.<region>.<cloud>.confluent.cloud:443
KAFKA_REST_ENDPOINT=
KAFKA_CLUSTER_ID=
KAFKA_ENV_ID=

# --- @schema (Schema Registry) ---
SCHEMA_REGISTRY_ENDPOINT=
SCHEMA_REGISTRY_API_KEY=
SCHEMA_REGISTRY_API_SECRET=

# --- @clusters / @environments / @connect / @catalog / @search / @billing (CCloud control plane) ---
CONFLUENT_CLOUD_REST_ENDPOINT=
CONFLUENT_CLOUD_API_KEY=
CONFLUENT_CLOUD_API_SECRET=
CONFLUENT_CLOUD_USERNAME=
CONFLUENT_CLOUD_PASSWORD=

# --- @flink ---
FLINK_REST_ENDPOINT=
FLINK_API_KEY=
FLINK_API_SECRET=
FLINK_ENV_ID=
FLINK_ORG_ID=
FLINK_COMPUTE_POOL_ID=
FLINK_DATABASE_NAME=
FLINK_CATALOG_NAME=

# --- @tableflow ---
TABLEFLOW_API_KEY=
TABLEFLOW_API_SECRET=

# --- @metrics (Telemetry API) ---
TELEMETRY_ENDPOINT=
TELEMETRY_API_KEY=
TELEMETRY_API_SECRET=
