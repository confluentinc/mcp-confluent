# Integration test environment — copy to .env.integration and fill in real values

# Kafka cluster credentials (@kafka tests)
KAFKA_API_KEY=
KAFKA_API_SECRET=
BOOTSTRAP_SERVERS=

# Confluent Cloud Kafka REST proxy — required for @kafka tests that exercise
# alter-topic-config / get-topic-config (which call /kafka/v3/... endpoints
# on the cluster's REST URL rather than the native Kafka admin client).
# KAFKA_REST_ENDPOINT typically looks like:
#   https://pkc-xxxxx.<region>.<cloud>.confluent.cloud:443
KAFKA_REST_ENDPOINT=
KAFKA_CLUSTER_ID=

