# =============================================================================
# Integration Test Environment Configuration
# =============================================================================
# Copy this file to .env.integration and fill in the values.
# These credentials are used by `npm run test:integration` to run real
# API calls against Confluent Cloud.
#
# WARNING: Tests create and delete real resources (topics, schemas, tags).
#          Use a dedicated development/staging environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Kafka (required for kafka tests)
# -----------------------------------------------------------------------------
BOOTSTRAP_SERVERS=""
KAFKA_API_KEY=""
KAFKA_API_SECRET=""
KAFKA_REST_ENDPOINT=""
KAFKA_CLUSTER_ID=""
KAFKA_ENV_ID="env-"

# -----------------------------------------------------------------------------
# Schema Registry (required for schema registry & catalog/search tests)
# -----------------------------------------------------------------------------
SCHEMA_REGISTRY_API_KEY=""
SCHEMA_REGISTRY_API_SECRET=""
SCHEMA_REGISTRY_ENDPOINT=""

# -----------------------------------------------------------------------------
# Confluent Cloud API (required for cloud infra, connect, billing tests)
# -----------------------------------------------------------------------------
CONFLUENT_CLOUD_API_KEY=""
CONFLUENT_CLOUD_API_SECRET=""
CONFLUENT_CLOUD_REST_ENDPOINT="https://api.confluent.cloud"
