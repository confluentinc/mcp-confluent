{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug MCP Server",
      "type": "node",
      "request": "launch",
      "runtimeVersion": "22",
      "program": "${workspaceFolder}/dist/index.js",
      "args": ["--config", "config.yaml", "--env-file", ".env"],
      "env": {
        "LOG_PRETTY": "true"
      },
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "sourceMaps": true,
      "console": "integratedTerminal",
      "preLaunchTask": "build",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
